MLOPS_APP_NAME=mlops-sentinel
MLOPS_APP_VERSION=0.2.0
MLOPS_DB_PATH=./data/sentinel.db
MLOPS_CORS_ORIGINS=http://127.0.0.1:4173,http://localhost:4173
MLOPS_ALLOWED_HOSTS=*
MLOPS_SUMMARY_SIZE=100
MLOPS_DRIFT_THRESHOLD=0.55
MLOPS_RATE_LIMIT_PER_MINUTE=600
MLOPS_MAX_PAYLOAD_BYTES=65536
MLOPS_GZIP_MINIMUM_SIZE=1024
MLOPS_ENABLE_HSTS=false
MLOPS_API_KEY=
MLOPS_API_KEY_SECRET_FILE=./secrets/mlops_api_key.txt
VITE_API_URL=http://127.0.0.1:8000
